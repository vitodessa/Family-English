# Скопируй в .env и заполни. Файл .env в git НЕ попадает (см. .gitignore).

# Секрет для подписи cookie-сессий. Сгенерировать:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-please

# База данных. По умолчанию — SQLite в папке data/ (постоянный диск).
# Чтобы переехать на PostgreSQL, заменить на:
#   postgresql+psycopg://user:pass@host:5432/family
# DATABASE_URL=sqlite:///./data/family.db

# Первый администратор создаётся при старте, если задан пароль.
ADMIN_NAME=admin
ADMIN_PASSWORD=

# Сколько карточек выдавать новому ученику на старте
INITIAL_CARDS=20
